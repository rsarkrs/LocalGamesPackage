{
  "name": "local-games",
  "version": "1.0.0",
  "description": "A local standalone app for small classic games.",
  "main": "electron-main.js",
  "author": "Rami Abou-Karr",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.localgames.collection",
    "productName": "Local Games",
    "files": [
      "electron-main.js",
      "preload.js",
      "index.html",
      "app.js",
      "styles.css",
      "games/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  }
}
